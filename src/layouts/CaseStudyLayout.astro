---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description, bodyClass } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass={bodyClass}>
  <a
    href="/"
    class="fixed top-6 right-6 z-[100] flex justify-center items-center w-12 h-12 bg-white rounded-full shadow-lg text-text-heading no-underline hover:scale-110 transition-transform"
    title="Fermer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
  </a>
  <slot />
</BaseLayout>
