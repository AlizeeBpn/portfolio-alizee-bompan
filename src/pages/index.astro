  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    // Sheryjs n'a pas d'équivalent npm ; l'URL est figée sur un commit précis
    // (au lieu de @main) pour éviter qu'un changement en amont, hors de notre
    // contrôle, ne modifie silencieusement le code exécuté sur le site.
    (function loadShery(cb) {
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/gh/aayushchouhan24/sheryjs@2cca9f312acc80bf31ce18ec0831e7ff769efd04/dist/Shery.js';
      s.onload = cb;
      document.head.appendChild(s);
    })(function() {
      gsap.registerPlugin(ScrollTrigger);

      gsap.from('#home .reveal-on-load', {
        y: 30, opacity: 0, filter: 'blur(15px)', duration: 0.8, ease: 'power3.out', stagger: 0.1
      });

      // Cat CV animation: fall from top with bounce & rotation, loop 8x
      var catLink = document.getElementById('cat-cv-link');
      var catImg = document.getElementById('cat-cv-img');
      if (catLink && catImg) {
        // Set initial state: well above viewport, rotated, invisible
        gsap.set(catLink, { y: -window.innerHeight, opacity: 0, rotation: -8 });

        // Animate: fall across the whole screen with natural bounce, slight rotation — loop 8 times
        gsap.to(catLink, {
          y: 0,
          opacity: 1,
          rotation: 5,
          duration: 1.5,
          ease: 'bounce.out',
          delay: 0.3,
          repeat: 7,
          repeatDelay: 2.5,
          onStart: function() {
            catImg.style.visibility = 'visible';
          },
          onComplete: function() {
            catLink.style.pointerEvents = 'auto';
          }
        });
      }

      var light = document.getElementById('cursor-light');
      if (light) {
        document.addEventListener('mousemove', function(e) {
          gsap.to(light, { left: e.clientX, top: e.clientY, duration: 0.3, ease: 'power2.out' });
        });
      }

      gsap.utils.toArray('#project .reveal-on-load, #expertise .reveal-on-load, footer .reveal-on-load').forEach(function(el) {
        gsap.from(el, {
          y: 10, opacity: 0, filter: 'blur(4px)', duration: 0.4, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 95%', toggleActions: 'play none none none' }
        });
      });

      gsap.utils.toArray('.split-words').forEach(function(el) {
        var text = el.textContent.trim();
        var words = text.split(' ');
        el.innerHTML = '';
        words.forEach(function(word) {
          var span = document.createElement('span');
          span.textContent = word + ' ';
          span.style.color = 'rgba(71,84,103,0.06)';
          el.appendChild(span);
        });
        gsap.to(el.querySelectorAll('span'), {
          color: '#475467',
          stagger: 0.015,
          scrollTrigger: { trigger: el, start: 'top 98%', end: 'bottom 30%', scrub: true }
        });
      });

      gsap.utils.toArray('.gsap-trigger-right').forEach(function(section) {
        var target = section.querySelector('.gsap-target');
        if (!target) return;
        gsap.to(target, { width: '65%', ease: 'none', scrollTrigger: { trigger: section, start: 'top 80%', end: 'bottom 20%', scrub: true } });
      });
      gsap.utils.toArray('.gsap-trigger-left').forEach(function(section) {
        var target = section.querySelector('.gsap-target');
        if (!target) return;
        gsap.to(target, { width: '65%', ease: 'none', scrollTrigger: { trigger: section, start: 'top 80%', end: 'bottom 20%', scrub: true } });
      });

      gsap.utils.toArray('.expertise-card').forEach(function(card) {
        var media = card.querySelector('.gsap-media');
        var textBox = card.querySelector('.gsap-text-box');
        if (!media || !textBox) return;
        gsap.to(media, { scale: 1, ease: 'none', scrollTrigger: { trigger: card, start: 'top bottom', end: 'bottom top', scrub: true } });
        gsap.from(textBox, { y: 40, opacity: 0, duration: 1, ease: 'power3.out', scrollTrigger: { trigger: card, start: 'top 75%' } });
      });

      // Dia reveal: character-by-character shimmer
      var diaEl = document.querySelector('.dia-reveal');
      if (diaEl) {
        var text = diaEl.textContent;
        diaEl.textContent = '';
        for (var i = 0; i < text.length; i++) {
          var span = document.createElement('span');
          span.textContent = text[i];
          span.style.opacity = '0';
          span.style.display = 'inline-block';
          diaEl.appendChild(span);
        }
        gsap.to(diaEl.querySelectorAll('span'), {
          opacity: 1,
          duration: 0.08,
          stagger: 0.06,
          ease: 'power2.out',
          scrollTrigger: { trigger: diaEl, start: 'top 85%' }
        });
      }

      // Mobile hamburger menu
      var hamburgerBtn = document.getElementById('hamburger-btn');
      var hamburgerIcon = document.getElementById('hamburger-icon');
      var hamburgerClose = document.getElementById('hamburger-close');
      var mobileMenu = document.getElementById('mobile-menu');
      if (hamburgerBtn && mobileMenu) {
        hamburgerBtn.addEventListener('click', function() {
          var isOpen = !mobileMenu.classList.contains('hidden');
          if (isOpen) {
            mobileMenu.classList.add('hidden');
            mobileMenu.classList.remove('flex');
            hamburgerIcon.classList.remove('hidden');
            hamburgerClose.classList.add('hidden');
          } else {
            mobileMenu.classList.remove('hidden');
            mobileMenu.classList.add('flex');
            hamburgerIcon.classList.add('hidden');
            hamburgerClose.classList.remove('hidden');
          }
        });
        // Close menu when a link is clicked
        mobileMenu.querySelectorAll('.mobile-nav-link').forEach(function(link) {
          link.addEventListener('click', function() {
            mobileMenu.classList.add('hidden');
            mobileMenu.classList.remove('flex');
            hamburgerIcon.classList.remove('hidden');
            hamburgerClose.classList.add('hidden');
          });
        });
      }

      // Shimmer button effect
      document.querySelectorAll('.shimmer-btn').forEach(function(btn) {
        btn.addEventListener('mouseenter', function() {
          var overlay = document.createElement('span');
          overlay.style.cssText = 'position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);pointer-events:none;';
          btn.appendChild(overlay);
          gsap.to(overlay, { left: '200%', duration: 0.6, onComplete: function() { overlay.remove(); } });
        });
      });

      Shery.imageEffect('.img', { style: 2, debug: true, config: { gooey: true, infinite: true, uSpeed: 0.3, uStrength: 5, displace: 1, respo: true } });
    });
  </script>
