---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';
import iniSearch1 from '../assets/ini-search-1.png';
import ini2fa1 from '../assets/ini-2fa-1.png';

const [optIniSearch1, optIni2fa1] = await Promise.all(
  [iniSearch1, ini2fa1].map((img) => getImage({ src: img, width: 800, format: 'webp' }))
);
---

<BaseLayout
  title="Alizée Bompan — Product Designer UX UI"
  description="Je transforme la complexité en interfaces qui ont du sens."
>

  <!-- ============================================================
       NAVIGATION
       ============================================================ -->
  <header class="w-full flex justify-center items-center">
    <nav class="z-[9999] fixed top-0 flex justify-center items-center gap-6 lg:gap-8 mx-auto mt-[.8rem] py-[.8rem] pl-6 lg:pl-8 pr-[.8rem] bg-[#f9f9fe0f] border border-[#b3b1b91f] rounded-full backdrop-blur-[15px] shadow-[0_2px_14px_-8px_#7659e952,inset_0_-6px_6px_-12px_#b09ccf33]">
      <!-- Desktop nav links -->
      <div class="hidden sm:flex items-center gap-6 lg:gap-8">
        <a href="#home" class="no-underline">
          <span class="font-['Plus_Jakarta_Sans',sans-serif] max-md:text-[.85rem] text-[1.1rem] font-medium text-text-body hover:text-brand transition-colors active:text-brand-deep active:scale-95">Accueil</span>
        </a>
        <a href="#project" class="no-underline">
          <span class="font-['Plus_Jakarta_Sans',sans-serif] max-md:text-[.85rem] text-[1.1rem] font-medium text-text-body hover:text-brand transition-colors active:text-brand-deep active:scale-95">Projets</span>
        </a>
        <a href="#expertise" class="no-underline">
          <span class="font-['Plus_Jakarta_Sans',sans-serif] max-md:text-[.85rem] text-[1.1rem] font-medium text-text-body hover:text-brand transition-colors active:text-brand-deep active:scale-95">Expertises</span>
        </a>
      </div>
      <!-- Mobile hamburger -->
      <button id="hamburger-btn" class="sm:hidden flex items-center justify-center w-10 h-10 text-text-body hover:text-brand transition-colors bg-transparent border-0 cursor-pointer" aria-label="Menu">
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="hamburger-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <a href="mailto:a.bpn148@gmail.com?subject=collaborons%20-" class="shimmer-btn relative z-10 flex justify-center items-center px-[1.7rem] py-[.8rem] rounded-[50vw] bg-brand-light no-underline overflow-hidden active:bg-brand-deep active:scale-[.97] max-sm:px-[1.2rem] max-sm:py-[.6rem]">
        <span class="relative z-10 font-['Plus_Jakarta_Sans',sans-serif] text-[1.1rem] max-sm:text-[.9rem] font-normal text-surface-card">Collaborons</span>
      </a>
    </nav>
    <!-- Mobile dropdown menu -->
    <div id="mobile-menu" class="z-[9998] fixed top-[4.5rem] left-1/2 -translate-x-1/2 w-[90vw] max-w-[300px] bg-[#f9f9fe] border border-[#b3b1b91f] rounded-2xl backdrop-blur-[15px] shadow-[0_8px_30px_-12px_#7659e952] py-4 px-2 flex-col items-center gap-2 hidden sm:hidden">
      <a href="#home" class="mobile-nav-link no-underline block w-full text-center py-3 rounded-xl">
        <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-medium text-text-body hover:text-brand transition-colors">Accueil</span>
      </a>
      <a href="#project" class="mobile-nav-link no-underline block w-full text-center py-3 rounded-xl">
        <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-medium text-text-body hover:text-brand transition-colors">Projets</span>
      </a>
      <a href="#expertise" class="mobile-nav-link no-underline block w-full text-center py-3 rounded-xl">
        <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-medium text-text-body hover:text-brand transition-colors">Expertises</span>
      </a>
    </div>
  </header>

  <main class="w-full">
    <!-- ============================================================
         HERO SECTION
         ============================================================ -->
    <section id="home" class="z-[1] sticky top-0 w-full h-screen overflow-hidden bg-[url('https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69c42950c1450604d9204d95_Rectangle%20(1).svg')] bg-cover bg-[0_0]">

      <div id="cursor-light" class="fixed w-[300px] h-[300px] rounded-full pointer-events-none z-50" style="background:radial-gradient(circle,rgba(131,78,255,0.45) 0%,transparent 70%);transform:translate(-50%,-50%);mix-blend-mode:screen;"></div>

      <div class="group cursor-pointer absolute bottom-[25%] right-[25%] max-sm:bottom-[2%] max-sm:right-[2%] max-sm:w-8 z-[2]">
        <img src="https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69e903cbb2a0f6b9c529e1f5_Fichier%201etoile-1.svg" loading="lazy" alt="" class="img w-10 z-[2] relative group-hover:scale-125 transition-transform duration-500" />
        <div class="z-[2] opacity-0 group-hover:opacity-100 absolute w-40 h-40 p-4 bg-[#e8d5f5] rotate-[-3deg] shadow-[0_1px_12px_-4px_#846cc559] transition-opacity duration-500">
          <p class="text-left font-['Caveat',Georgia,sans-serif] text-[1.3rem] leading-[100%]">Progressive disclosure ou écran par étapes ?</p>
        </div>
      </div>

      <div class="z-[1] flex flex-col justify-end items-start w-full h-full mb-0 pt-0 pb-20 pl-20 pr-20 gap-4 max-lg:pb-0 max-lg:pl-0 max-md:pb-12 max-md:pl-6 max-md:pr-6 max-sm:justify-center max-sm:items-center max-sm:pb-8 max-sm:pl-4 max-sm:pr-4 max-sm:overflow-visible">

        <div class="group cursor-pointer z-10 relative">
          <img src="https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69e903cb889ee6a3e4bf5808_Fichier%204etoile-4.svg" loading="lazy" alt="" class="img w-12 z-[1] max-sm:w-8 group-hover:scale-125 transition-transform duration-500" />
          <div class="z-10 opacity-0 group-hover:opacity-100 absolute w-40 h-40 p-4 bg-[#e8d5f5] rotate-[-4deg] shadow-[0_2px_5px_#846cc559] transition-opacity duration-500">
            <p class="text-left font-['Caveat',Georgia,sans-serif] text-[1.3rem] leading-[100%]">Si 8 à 90° = ∞ <br/>&nbsp;or U(=ↀωↀ=)X<br/>&nbsp;donc UX for ∞</p>
          </div>
        </div>

        <div class="z-[1] flex flex-col gap-[1.2rem] static max-sm:text-center max-sm:justify-center max-sm:items-center max-sm:my-8">
          <div class="reveal-on-load flex items-center gap-[.6rem] mb-2 max-md:justify-center">
            <span class="w-[7px] h-[7px] rounded-full bg-[#7b4fd4] flex-shrink-0"></span>
            <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[#7b4fd4] max-md:text-[.9rem] max-sm:text-[.8rem] text-[1.1rem] font-semibold tracking-[.18em] uppercase max-md:text-center">Alizée Bompan</span>
            <span class="w-[7px] h-[7px] rounded-full bg-[#7b4fd4] flex-shrink-0"></span>
          </div>
          <div class="z-[2] relative max-sm:text-center">
            <h1 class="reveal-on-load mt-0 mb-0 font-['Pphatton',Georgia,sans-serif] 2xl:text-[6rem] max-md:text-[3rem] max-sm:text-[2.2rem] text-[3rem] font-bold leading-[1.1] text-brand max-sm:text-center max-md:text-center inline">Product Designer <span class="text-text-heading">UX UI</span></h1>
          </div>
        </div>

        <p class="reveal-on-load z-[1] relative mt-4 mb-8 font-['Plus_Jakarta_Sans',sans-serif] text-text-muted 2xl:text-[1.5rem] max-md:text-[1.1rem] max-sm:text-[.95rem] max-sm:leading-[1.6rem] text-[1.25rem] font-normal leading-[1.6] max-md:text-center max-sm:text-center">
          Je transforme la complexité en interfaces qui ont du sens.
        </p>

        <div class="flex flex-col">
          <div class="reveal-on-load flex gap-12 max-md:justify-center max-md:items-center">
            <div class="reveal-on-load flex flex-col justify-center items-center w-[6.5rem] h-[6.5rem] border border-[#cbccd65c] rounded-[.8rem] relative">
              <span class="z-[2] relative font-['Plus_Jakarta_Sans',sans-serif] text-[#1a1425] text-[2rem] font-extrabold leading-[1] tracking-[-.02em]">2+</span>
              <span class="z-[2] relative mt-1 font-['Plus_Jakarta_Sans',sans-serif] text-[#8b7fa8] text-[.7rem] font-medium tracking-[.15em] uppercase">Ans d'exp.</span>
              <div class="z-[1] absolute inset-0 bg-[#f6f3fd8a] blur-[15px]"></div>
            </div>
            <div class="flex flex-col justify-center items-center w-[6.5rem] h-[6.5rem] border border-[#cbccd65c] rounded-[.8rem] relative">
              <span class="z-[2] relative font-['Plus_Jakarta_Sans',sans-serif] text-[#1a1425] text-[2rem] font-extrabold leading-[1] tracking-[-.02em]">10+</span>
              <span class="z-[2] relative mt-1 font-['Plus_Jakarta_Sans',sans-serif] text-[#8b7fa8] text-[.7rem] font-medium tracking-[.15em] uppercase">Projets</span>
              <div class="z-[1] absolute inset-0 bg-[#f6f3fd8a] blur-[15px]"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="group cursor-pointer absolute top-[8%] right-[8%] max-sm:top-[2%] max-sm:right-[2%] max-sm:w-8">
        <img src="https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69e903cbfe85c8c305f9e75b_Fichier%203etoile-3.svg" loading="lazy" alt="" class="img w-12 z-[2] relative max-sm:w-8 group-hover:scale-125 transition-transform duration-500" />
        <div class="z-[2] opacity-0 group-hover:opacity-100 absolute w-40 h-40 p-4 bg-[#e8d5f5] rotate-[-3deg] shadow-[0_1px_12px_-4px_#846cc559] transition-opacity duration-500">
          <p class="text-left font-['Caveat',Georgia,sans-serif] text-[1.3rem] leading-[100%]">Vérifier l'affordance du bouton</p>
        </div>
      </div>

      <a id="cat-cv-link" href="/cv_alizeebompan.pdf" target="_blank" class="z-[2] absolute bottom-[2%] right-[5%] max-sm:bottom-[2%] max-sm:right-[4%]" style="pointer-events: none; cursor: pointer;" rel="noopener noreferrer">
        <img id="cat-cv-img" src="https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69eb6d779c0dd553dea4113d_chat-cv.PNG" alt="chat" class="img pointer-events-auto cursor-pointer object-contain block w-[6vw] min-w-[44px] max-w-[80px] h-auto opacity-100" style="visibility: hidden;" />
      </a>
    </section>

    <!-- ============================================================
         PROJECTS SECTION
         ============================================================ -->
    <section id="project" class="z-30 w-full bg-surface-card flex justify-center pt-[80px] lg:pt-[100px] pb-[80px] lg:pb-[100px] relative border-b border-[#eff9fc1a] max-lg:pt-[120px] max-lg:pb-[120px] max-md:pt-[80px] max-md:pb-[80px] max-sm:pt-[60px] max-sm:pb-[60px]">

      <div class="z-[25] grid grid-cols-[minmax(5vw,1fr)_minmax(auto,1400px)_minmax(5vw,1fr)] 2xl:grid-cols-[minmax(2vw,1fr)_minmax(auto,1700px)_minmax(2vw,1fr)] grid-rows-[auto] w-full relative max-md:grid-cols-[1vw_minmax(auto,100%)_1vw] max-md:overflow-hidden max-sm:grid-cols-[0_minmax(0,100%)_0] max-sm:mx-0 max-sm:overflow-hidden">
        <div class="grid grid-cols-1 gap-x-4 gap-y-12" style="grid-area: 1 / 2 / 2 / 3;">
          <div class="grid grid-cols-1 gap-x-12 gap-y-[100px] lg:gap-y-[140px] 2xl:gap-y-[180px] max-md:gap-y-[80px]">

            <!-- Project 0: Initiative CRM (NEW) — left image grows rightward -->
            <article class="grid grid-cols-[1fr_65%] gap-x-12 lg:gap-x-20 2xl:gap-x-24 gap-y-4 mb-8 pt-8 border-t-0 max-lg:grid-cols-1 max-lg:gap-y-20 max-md:gap-y-10 max-md:mx-8 max-sm:grid-cols-1 max-sm:gap-y-6 max-sm:mt-4 max-sm:mx-4">
              <div class="flex flex-col justify-between max-w-[500px] max-sm:max-w-full">
                <div>
                  <div class="grid grid-cols-1 gap-x-4 gap-y-[18px] max-w-[675px]">
                    <div class="flex flex-col gap-[1.2rem] max-lg:gap-y-6">
                      <span class="reveal-on-load w-full text-left font-['Plus_Jakarta_Sans',sans-serif] text-brand-light 2xl:text-[1.2rem] max-sm:text-[.85rem] text-[1rem]">UX UI Designer — Alternance 2 ans</span>
                      <h2 class="reveal-on-load font-['Pphatton',Georgia,sans-serif] 2xl:text-[3.8rem] max-lg:text-[2.2rem] max-md:text-[1.8rem] max-sm:text-[1.5rem] text-[3rem] font-medium leading-[1.4] text-[#423e46]">Initiative CRM</h2>
                    </div>
                    <div class="max-w-[500px]">
                      <p class="split-words font-['Plus_Jakarta_Sans',sans-serif] 2xl:text-[1.3rem] max-md:text-[.95rem] max-sm:text-[1rem] max-sm:leading-[150%] text-[20px] leading-[140%] text-[#5f5969]">
                        Design UX/UI d'un SaaS B2B complexe en méthodologie Shape Up. Du cadrage au handoff technique, je construis les parcours de nouvelles fonctionnalités et je modernise la plateforme via un Design System.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="flex justify-end mt-6 max-sm:hidden">
                  <a href="/project-ux/initiative-crm" class="shimmer-btn no-underline relative overflow-hidden z-10 inline-flex justify-center items-center px-[1.5rem] py-[.7rem] rounded-[50vw] bg-brand-light active:bg-brand-deep active:scale-[.97]">
                    <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-normal text-surface-card">Voir le projet</span>
                  </a>
                </div>
              </div>
              <div class="max-md:max-w-full max-md:overflow-hidden">
                <div class="gsap-trigger-left h-[35vw] max-lg:h-[45vw] max-md:h-[60vw] max-sm:h-[55vw] 2xl:max-h-[650px] overflow-hidden flex flex-nowrap w-full relative">
                  <div class="gsap-target relative z-10 flex-[0_auto] w-[40%] h-full mr-6 overflow-visible flex-shrink-0 bg-accent-peach bg-cover bg-center" style={`background-image:url(${optIniSearch1.src})`}></div>
                  <div class="flex-1 w-[35%] h-full mr-0 relative overflow-hidden z-[1] bg-accent-azure bg-cover bg-center" style={`background-image:url(${optIni2fa1.src})`}></div>
                </div>
              </div>
              <div class="flex justify-end mt-6 sm:hidden">
                <a href="/project-ux/initiative-crm" class="shimmer-btn no-underline relative overflow-hidden z-10 inline-flex justify-center items-center px-[1.5rem] py-[.7rem] rounded-[50vw] bg-brand-light active:bg-brand-deep active:scale-[.97]">
                  <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-normal text-surface-card">Voir le projet</span>
                </a>
              </div>
            </article>

            <!-- Project 1: Bibliothèque de Bordeaux -->
            <article class="grid grid-cols-[1fr_65%] gap-x-12 lg:gap-x-20 2xl:gap-x-24 gap-y-4 mb-8 pt-8 border-t-0 max-lg:grid-cols-1 max-lg:gap-y-20 max-md:gap-y-10 max-md:mx-8 max-sm:grid-cols-1 max-sm:gap-y-6 max-sm:mt-4 max-sm:mx-4">
              <div class="flex flex-col justify-between max-w-[500px] max-sm:max-w-full">
                <div>
                  <div class="grid grid-cols-1 gap-x-4 gap-y-[18px] max-w-[675px]">
                    <div class="flex flex-col gap-[1.2rem] max-lg:gap-y-6">
                      <span class="reveal-on-load w-full text-left font-['Plus_Jakarta_Sans',sans-serif] text-brand-light 2xl:text-[1.2rem] max-sm:text-[.85rem] text-[1rem]">Projet de fin d'étude &nbsp;UX UI</span>
                      <h2 class="reveal-on-load font-['Pphatton',Georgia,sans-serif] 2xl:text-[3.8rem] max-lg:text-[2.2rem] max-md:text-[1.8rem] max-sm:text-[1.5rem] text-[3rem] font-medium leading-[1.2] text-[#423e46]">Bibliothèque de Bordeaux</h2>
                    </div>
                    <div class="max-w-[500px]">
                      <p class="split-words font-['Plus_Jakarta_Sans',sans-serif] 2xl:text-[1.3rem] max-md:text-[.95rem] max-sm:text-[1rem] max-sm:leading-[150%] text-[20px] leading-[140%] text-[#5f5969]">
                        Faciliter le quotidien des abonnés avec un compagnon de service mobile : une interface pour explorer le catalogue, réserver un titre et suivre ses listes de lecture.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="flex justify-end mt-6 max-sm:hidden">
                  <a href="/project-ux/application-bibliotheque-de-bordeaux" class="shimmer-btn no-underline relative overflow-hidden z-10 inline-flex justify-center items-center px-[1.5rem] py-[.7rem] rounded-[50vw] bg-brand-light active:bg-brand-deep active:scale-[.97]">
                    <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-normal text-surface-card">Voir le projet</span>
                  </a>
                </div>
              </div>
              <div class="max-md:max-w-full max-md:overflow-hidden">
                <div class="gsap-trigger-right h-[35vw] max-lg:h-[45vw] max-md:h-[60vw] max-sm:h-[55vw] 2xl:max-h-[650px] overflow-hidden flex flex-nowrap w-full relative">
                  <div class="flex-1 w-[40%] h-full mr-6 relative z-[1]">
                    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image:url('https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69ea58e02e8f820ce139a897_bibliomoque%20(1).png')"></div>
                  </div>
                  <div class="gsap-target relative z-10 flex-[0_auto] w-[35%] h-full mr-0 overflow-visible flex-shrink-0 bg-accent-lavender bg-cover bg-center" style="background-image:url('https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69ea5923531fe6400e4f9e7e_Gemini_Generated_Image_bbupskbbupskbbup%20(1).png')"></div>
                </div>
              </div>
              <div class="flex justify-end mt-6 sm:hidden">
                <a href="/project-ux/application-bibliotheque-de-bordeaux" class="shimmer-btn no-underline relative overflow-hidden z-10 inline-flex justify-center items-center px-[1.5rem] py-[.7rem] rounded-[50vw] bg-brand-light active:bg-brand-deep active:scale-[.97]">
                  <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-normal text-surface-card">Voir le projet</span>
                </a>
              </div>
            </article>

            <!-- Project 2: Netflix -->
            <article class="grid grid-cols-[1fr_65%] gap-x-12 lg:gap-x-20 2xl:gap-x-24 gap-y-4 mb-8 pt-8 border-t-0 max-lg:grid-cols-1 max-lg:gap-y-20 max-md:gap-y-10 max-md:mx-8 max-sm:grid-cols-1 max-sm:gap-y-6 max-sm:mt-4 max-sm:mx-4">
              <div class="flex flex-col justify-between max-w-[500px] max-sm:max-w-full">
                <div>
                  <div class="grid grid-cols-1 gap-x-4 gap-y-[18px] max-w-[675px]">
                    <div class="flex flex-col gap-[1.2rem] max-lg:gap-y-6">
                      <span class="reveal-on-load w-full text-left font-['Plus_Jakarta_Sans',sans-serif] text-brand-light 2xl:text-[1.2rem] max-sm:text-[.85rem] text-[1rem]">UX Research & Design — 2024</span>
                      <h2 class="reveal-on-load font-['Pphatton',Georgia,sans-serif] 2xl:text-[3.8rem] max-lg:text-[2.2rem] max-md:text-[1.8rem] max-sm:text-[1.5rem] text-[3rem] font-medium leading-[1.4] text-[#423e46]">Netflix</h2>
                    </div>
                    <div class="max-w-[500px]">
                      <p class="split-words font-['Plus_Jakarta_Sans',sans-serif] 2xl:text-[1.3rem] max-md:text-[.95rem] max-sm:text-[1rem] max-sm:leading-[150%] text-[20px] leading-[140%] text-[#5f5969]">
                        Safe N Chill, un dispositif UX permettant de filtrer l'exposition à la violence cinématographique, couplé à Chill N learn, un système d'apprentissage autonome pour approfondir ses connaissances.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="flex justify-end mt-6 max-sm:hidden">
                  <a href="/project-ux/netflix" class="shimmer-btn no-underline relative overflow-hidden z-10 inline-flex justify-center items-center px-[1.5rem] py-[.7rem] rounded-[50vw] bg-brand-light active:bg-brand-deep active:scale-[.97]">
                    <span class="font-['Plus_Jakarta_Sans',sans-serif] text-[1rem] font-normal text-surface-card">Voir le projet</span>
                  </a>
                </div>
              </div>
              <div class="max-md:max-w-full max-md:overflow-hidden">
                <div class="gsap-trigger-left h-[35vw] max-lg:h-[45vw] max-md:h-[60vw] max-sm:h-[55vw] 2xl:max-h-[650px] overflow-hidden flex flex-nowrap w-full relative">
                  <div class="gsap-target relative z-10 flex-[0_auto] w-[40%] h-full mr-6 overflow-visible flex-shrink-0 bg-surface-card bg-cover bg-center" style="background-image:url('https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69e91832f91f6186e60d2768_behance-680e7adfc558d_pages-to-jpg-0065.jpg')"></div>
                  <div class="flex-1 w-[35%] h-full mr-0 relative overflow-hidden z-[1] bg-accent-lavender bg-cover bg-center" style="background-image:url('https://cdn.prod.website-files.com/69aaefbda0cd3c8e21a062de/69e91918cae8f8256abc3fd9_f872ce224611677.Y3JvcCwxNDI0LDExMTQsNyww.png')"></div>
                </div>
