---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
---

<CaseStudyLayout title="Billetterie en ligne Reggae — Alizée Bompan">
  <main class="w-full">
    <div class="flex flex-col gap-10 w-full max-w-[900px] mx-auto pt-8 pb-16 px-6 md:px-12">
      <span class="text-brand-light tracking-[.12em] uppercase text-xs font-medium">Google UX Design</span>
      <h1 class="font-['Pphatton',Georgia,sans-serif] [overflow-wrap:anywhere] max-lg:text-[3rem] max-md:text-[2.4rem] max-sm:text-[1.9rem] text-[4rem] font-extrabold leading-[1] text-text-heading">Billetterie en ligne Reggae</h1>
      <p class="font-['Plus_Jakarta_Sans',sans-serif] text-text-muted max-lg:text-[1.2rem] max-md:text-[1.1rem] max-sm:text-[1rem] text-[1.4rem] leading-[1.6]">
        Conception d'une plateforme de billetterie en ligne dédiée à la culture reggae — identité visuelle chaleureuse, expérience d'achat fluide et immersive. Décliné sur trois devices (desktop, mobile, tablette).
      </p>
      <hr class="border-[#00000012] w-full" />
      <div class="flex flex-wrap gap-12 gap-y-6">
        <div class="flex flex-col gap-1">
          <span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">2023</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">Figma</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">reggae-music-billetterie</span>
        </div>
      </div>
    </div>

<div class="w-full max-w-[1100px] mx-auto flex flex-col">
