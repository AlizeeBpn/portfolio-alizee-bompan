---

<CaseStudyLayout title="Netflix — Safe N Chill — Alizée Bompan">
  <main class="w-full">
    <div class="flex flex-col gap-10 w-full max-w-[900px] mx-auto pt-8 pb-16 px-6 md:px-12">
      <span class="text-brand-light tracking-[.12em] uppercase text-xs font-medium">UX Research & Design</span>
      <h1 class="font-['Pphatton',Georgia,sans-serif] [overflow-wrap:anywhere] max-lg:text-[3rem] max-md:text-[2.4rem] max-sm:text-[1.9rem] text-[4rem] font-extrabold leading-[1] text-text-heading">Netflix</h1>
      <p class="font-['Plus_Jakarta_Sans',sans-serif] text-text-muted max-lg:text-[1.2rem] max-md:text-[1.1rem] max-sm:text-[1rem] text-[1.4rem] leading-[1.6]">
        Safe N Chill, un dispositif UX permettant de filtrer l'exposition à la violence cinématographique, couplé à Chill N learn, un système d'apprentissage autonome pour approfondir ses connaissances.
      </p>
      <hr class="border-[#00000012]" />
      <div class="flex flex-wrap gap-12 gap-y-6">
        <div class="flex flex-col gap-1">
          <span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">2024</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">Figma, UX Research</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">netflix-safe-n-chill</span>
        </div>
      </div>
    </div>

<div class="w-full max-w-[1100px] mx-auto flex flex-col">
      {images.map((img) => (
        <img src={img.src} alt="Netflix Safe N Chill" class="w-full block" loading="lazy" />
      ))}
    </div>
  </main>
</CaseStudyLayout>