---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import { getImage } from 'astro:assets';
import ini2fa from '../../assets/project-ini-1.png';
import iniSearch from '../../assets/project-ini-2.png';
import iniSearch1 from '../../assets/ini-search-1.png';
import ini2fa1 from '../../assets/ini-2fa-1.png';
import iniShowcase from '../../assets/project-showcase-global-search.png';

// Recompressées/redimensionnées au build via astro:assets — les sources d'origine
// vont jusqu'à 3837×1965px et étaient envoyées telles quelles au mobile.
const [optIni2fa, optIniSearch, optIniSearch1, optIni2fa1, optIniShowcase] = await Promise.all(
  [ini2fa, iniSearch, iniSearch1, ini2fa1, iniShowcase].map((img) =>
    getImage({ src: img, width: 900, format: 'webp' })
  )
);

const projectsWithImages = [
  { img: optIniSearch1.src, title:'Recherche globale', id:'01', desc:'CRM Initiative', long:"Refonte d'une fonctionnalité de recherche globale vieillissante pour la recentrer sur les véritables usages de nos clients. En m'appuyant sur de la recherche utilisateur (questionnaires et entretiens), j'ai repensé l'architecture de l'information pour y intégrer des raccourcis stratégiques. Résultat : un parcours de recherche optimisé, plus intuitif, avec un taux de rétention à 7 jours maintenu au-dessus des 90%.", tags:['UX Research','Data','Architecture'], color:'#0090FF' },
  { img: optIniSearch.src, title:'Comptes-rendus IA', id:'02', desc:'Réunions Teams • CRM Initiative', long:"Intégration de l'IA pour automatiser la création de comptes-rendus commerciaux. Participation au \"shaping\" du projet, rédaction de prompts, design des notifications et création de l'onboarding pour faciliter la découverte et l'adoption de cette nouvelle fonctionnalité.", tags:['IA','Shape Up','Onboarding'], color:'#12A594' },
  { img: optIni2fa.src, title:'Refonte App Mobile', id:'03', desc:'Application Initiative • React Native', long:"Refonte UX/UI de l'application mobile en équipe. Réalisation d'un audit ergonomique, création de wireframes et utilisation d'un Design System React Native. Création rapide d'un prototype fonctionnel (V0) pour tester les flux utilisateurs, en intégrant des outils IA dans le processus de design.", tags:['Mobile','React Native','Prototype'], color:'#0090FF' },
  { img: optIniSearch.src, title:'Design System', id:'04', desc:'Composants & Documentation • CRM Initiative', long:"Unification visuelle du CRM pour corriger les incohérences entre deux anciens designs coexistants. Création et migration des composants sur Figma, mise à jour des variables et synchronisation avec le Storybook. Rédaction d'une documentation claire pour rendre l'équipe autonome.", tags:['Figma','Storybook','Composants'], color:'#12A594' },
  { img: optIni2fa1.src, title:'Parcours d\'activation 2FA', id:'05', desc:'Sécurité • CRM Initiative', long:"Conception du parcours d'activation de la double authentification. Un travail centré sur l'UX Writing et l'accompagnement via Product Fruits pour réduire la friction sur une étape souvent perçue comme contraignante. Résultat : une adoption réussie par 71% des utilisateurs actifs.", tags:['UX Writing','Friction UX','Sécurité'], color:'#0090FF' },
  { img: optIniShowcase.src, title:'Tableaux de suivi d\'activité', id:'06', desc:'Dashboards B2B • CRM Initiative', long:"Création d'un formulaire permettant aux managers commerciaux de configurer des tableaux de bord sur-mesure (plusieurs indicateurs et périodes). Mise en page pensée pour une lecture rapide des données, avec un fort accent sur la clarté visuelle et l'UX writing pour des utilisateurs non techniques.", tags:['Data','B2B','Interface'], color:'#0090FF' },
  { img: optIniSearch.src, title:'Édition de devis', id:'07', desc:'Ajout de sections • CRM Initiative', long:"Conception d'un système d'ajout de sections personnalisées et de texte libre dans une interface de devis très dense. Travail d'audit et de \"shaping\" pour hiérarchiser l'information, suivi d'une livraison Figma claire pour faciliter l'intégration technique en autonomie.", tags:['UX Audit','Handoff','Structuration'], color:'#12A594' }
];
---

<CaseStudyLayout title="Initiative CRM — Alizée Bompan" bodyClass="w-full bg-[#F8FAFA]">

  <main class="w-full">
    <div class="flex flex-col gap-10 w-full max-w-[900px] mx-auto pt-8 pb-16 px-6 md:px-12">
      <span class="text-brand-light tracking-[.12em] uppercase text-xs font-medium">UX UI Designer — Alternance 2 ans</span>
      <h1 class="font-['Pphatton',Georgia,sans-serif] max-lg:text-[3rem] max-md:text-[2.4rem] max-sm:text-[1.9rem] text-[4rem] font-extrabold leading-[1] text-text-heading">Initiative CRM</h1>
      <p class="font-['Plus_Jakarta_Sans',sans-serif] text-text-muted max-lg:text-[1.2rem] max-md:text-[1.1rem] max-sm:text-[1rem] text-[1.4rem] leading-[1.6]">
        Design UX/UI d'un SaaS B2B complexe en méthodologie Shape Up. Du cadrage au handoff technique, je construis les parcours de nouvelles fonctionnalités et je modernise la plateforme via un Design System.
      </p>
      <hr class="border-[#00000012] w-full" />
      <div class="flex flex-wrap gap-12 gap-y-6">
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">2025 — En cours</span></div>
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">Figma, Shape Up, Design System</span></div>
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">initiative-crm</span></div>
      </div>
    </div>
  </main>

  <!-- PROJECT STAGE -->
  <div class="project-stage relative w-full max-w-5xl mx-auto mt-20 px-4 max-md:mt-10 max-md:flex max-md:flex-col max-md:gap-6">
    <!-- Stage Frame (image) -->
    <div id="stage-frame" style="border-color:#C2E5FF;box-shadow:4px 4px 0px 0px rgba(0,144,255,1),0px 12px 32px 0px rgba(142,200,246,0.12),inset 0px -6px 0px 0px rgba(0,0,51,0.06);" class="bg-blue-50 border rounded-3xl p-8 md:p-12 relative overflow-hidden transition-all duration-400 ease-[cubic-bezier(0.33,1,0.68,1)] cursor-pointer max-md:!p-4 max-md:cursor-default">
      <div id="project-img-wrapper" class="rounded-2xl overflow-hidden border border-[#C2E5FF]">
        <img id="project-main-img" src={optIniSearch1.src} width={optIniSearch1.attributes.width} height={optIniSearch1.attributes.height} class="w-full h-auto object-contain aspect-[4/3]" alt="Project mockup" />
      </div>
      <div id="watermark" class="absolute top-4 left-8 text-[120px] font-extrabold font-sans leading-none select-none pointer-events-none z-0 max-md:text-[60px] max-md:top-2 max-md:left-4" style="color:#0090FF12">01</div>
    </div>

    <!-- Project Card (desktop: absolute overlay, mobile: static below image) -->
    <div id="project-card" style="box-shadow:4px 4px 0px 0px rgba(0,144,255,1),0px 12px 32px 0px rgba(142,200,246,0.12);" class="absolute -bottom-10 -left-6 md:-left-10 z-10 w-[340px] md:w-[400px] bg-white rounded-2xl shadow-2xl p-6 md:p-8 border border-gray-100 transition-all duration-400 ease-[cubic-bezier(0.33,1,0.68,1)] max-md:!relative max-md:!bottom-auto max-md:!left-auto max-md:!w-full max-md:!z-0 max-md:cursor-default">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h3 id="project-title" class="font-sans text-[28px] font-extrabold text-[#102848] mb-1 max-md:text-[22px]">Recherche globale</h3>
          <p id="project-desc" class="font-sans text-[13px] font-medium text-[#0090FF]">CRM Initiative</p>
        </div>
        <span id="project-number" class="w-12 h-12 rounded-xl flex items-center justify-center font-extrabold text-lg" style="background-color:#0090FF1A;color:#0090FF">01</span>
      </div>
      <div id="separator" class="w-12 h-[3px] rounded-sm mb-4" style="background-color:#0090FF66"></div>
      <p id="project-long" class="text-[#102848A6] text-sm leading-[22px] mb-6">
        Refonte d'une fonctionnalité de recherche globale vieillissante pour la recentrer sur les véritables usages de nos clients. En m'appuyant sur de la recherche utilisateur (questionnaires et entretiens), j'ai repensé l'architecture de l'information pour y intégrer des raccourcis stratégiques. Résultat : un parcours de recherche optimisé, plus intuitif, avec un taux de rétention à 7 jours maintenu au-dessus des 90%.
      </p>
      <div id="project-tags" class="flex gap-2 mb-5">
        <span class="text-[11px] px-[10px] py-1 rounded-full font-medium" style="background:#0090FF26;color:#0090FF">UX Research</span>
        <span class="text-[11px] px-[10px] py-1 rounded-full font-medium" style="background:#0090FF26;color:#0090FF">Data</span>
        <span class="text-[11px] px-[10px] py-1 rounded-full font-medium" style="background:#0090FF26;color:#0090FF">Architecture</span>
      </div>
    </div>

    <!-- Mobile navigation arrows + indicator -->
    <div class="hidden max-md:flex items-center justify-center gap-4 py-2">
      <button id="mobile-prev" class="w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center hover:bg-gray-50 active:scale-95 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#102848" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <span id="mobile-indicator" class="font-sans font-bold text-[#102848] text-sm">1 / 7</span>
      <button id="mobile-next" class="w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center hover:bg-gray-50 active:scale-95 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#102848" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
      </button>
    </div>
  </div>

  <!-- TIMELINE NAVIGATION -->
  <div class="sticky bottom-0 w-full bg-white/80 backdrop-blur-md border-t border-gray-100 py-6 z-40 mt-20">
    <div class="w-full px-8 overflow-x-auto">
      <div id="timeline-row" class="relative flex flex-nowrap items-start w-max mx-auto gap-[70px] max-md:gap-8" style="padding-top:6px;padding-bottom:6px">
        <div class="absolute left-0 right-0 h-px border-0 pointer-events-none" style="top:97px;background:repeating-linear-gradient(to right, #12A594 0, #12A594 4px, transparent 4px, transparent 8px)"></div>
        {projectsWithImages.map((p, i) => (
          <div id={`step-${i}`} class="timeline-step flex flex-col items-center cursor-pointer relative z-10 flex-shrink-0 w-[156px] gap-[9px]">
            <span class="w-12 h-12 rounded-xl flex items-center justify-center font-extrabold text-lg"
                  style={i === 0
                    ? "font-weight:800;background-color:#12A59426;color:#0E9888;border:1px dashed #12A594;box-shadow:0px 3px 20px 0px rgba(18,165,148,0.15)"
                    : "font-weight:800;background-color:#0090FF1A;color:#0090FF;border:none;box-shadow:none"}>
              {p.id}
            </span>
            <span class="text-[11px] font-semibold whitespace-nowrap text-[#102848]">{p.title}</span>
            <span class="w-4 h-4 bg-[#12A594] rounded-full flex-shrink-0" style="box-shadow:0 0 6px 2px rgba(83,185,171,0.5)"></span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Injecter les données côté serveur → client via define:vars -->
  <script define:vars={{ projectsData: JSON.stringify(projectsWithImages) }}>
    var PROJECTS = JSON.parse(projectsData);
    var currentIndex = 0;
    var totalProjects = PROJECTS.length;

    var card = document.querySelector('#project-card');
    var stageFrame = document.querySelector('#stage-frame');
    var isAnimating = false;
    var cardOnTop = true;

    // ── Drag state ──
    var dragTarget = null;
    var dragStartX = 0, dragStartY = 0;
    var elemStartX = 0, elemStartY = 0;
    var dragged = false;

    // Store accumulated drag offsets per element
    var dragOffsets = {};
    dragOffsets['card'] = { x: 0, y: 0 };
    dragOffsets['stage'] = { x: 0, y: 0 };

    function applyDragOffset(el, key) {
      var o = dragOffsets[key];
      el.style.transform = 'translate(' + o.x + 'px, ' + o.y + 'px)';
    }

    function resetDrag(key) {
      dragOffsets[key] = { x: 0, y: 0 };
      if (key === 'card') { card.style.transform = ''; }
      else { stageFrame.style.transform = ''; }
    }

    // ── Make both cards draggable ──
    function makeDraggable(el, key) {
      el.addEventListener('mousedown', function(e) {
        if (isAnimating) return;
        e.preventDefault();
        dragTarget = el;
        dragged = false;
        dragStartX = e.clientX;
        dragStartY = e.clientY;
        elemStartX = dragOffsets[key].x;
        elemStartY = dragOffsets[key].y;
        el.style.transition = 'none';
        el.style.cursor = 'grabbing';
      });

      el.addEventListener('touchstart', function(e) {
        if (isAnimating) return;
        if (e.touches.length !== 1) return;
        var t = e.touches[0];
        dragTarget = el;
        dragged = false;
        dragStartX = t.clientX;
        dragStartY = t.clientY;
        elemStartX = dragOffsets[key].x;
        elemStartY = dragOffsets[key].y;
        el.style.transition = 'none';
      }, { passive: false });
    }

    function onMove(e) {
      if (!dragTarget) return;
      var cx, cy;
      if (e.touches) { cx = e.touches[0].clientX; cy = e.touches[0].clientY; }
      else { cx = e.clientX; cy = e.clientY; }
      var dx = cx - dragStartX;
      var dy = cy - dragStartY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) dragged = true;
      var key = dragTarget === card ? 'card' : 'stage';
      dragOffsets[key].x = elemStartX + dx;
      dragOffsets[key].y = elemStartY + dy;
      dragTarget.style.transform = 'translate(' + dragOffsets[key].x + 'px, ' + dragOffsets[key].y + 'px)';
    }

    function onUp() {
      if (!dragTarget) return;
      var key = dragTarget === card ? 'card' : 'stage';
      dragTarget.style.transition = 'transform 0.4s cubic-bezier(0.33,1,0.68,1)';
      dragTarget.style.cursor = '';
      dragTarget = null;
    }

    makeDraggable(card, 'card');
    makeDraggable(stageFrame, 'stage');
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
    document.addEventListener('touchmove', onMove, { passive: false });
    document.addEventListener('touchend', onUp);

    // ── Z-index swap (only on non-drag clicks) ──
    stageFrame.addEventListener('click', function(e){
      if (dragged || isAnimating) { dragged = false; return; }
      e.stopPropagation();
      cardOnTop = false;
      card.style.zIndex = '5';
      stageFrame.style.zIndex = '20';
    });

    card.addEventListener('click', function(e){
      if (dragged || isAnimating) { dragged = false; return; }
      e.stopPropagation();
      cardOnTop = true;
      card.style.zIndex = '10';
      stageFrame.style.zIndex = '0';
    });

    // ── Project switcher (resets drag positions) ──
    function switchProject(idx) {
      if (idx === currentIndex || isAnimating) return;
      isAnimating = true;
      var p = PROJECTS[idx];

      // Reset drag offsets
      resetDrag('card');
      resetDrag('stage');

      // Phase 1: retreat
      card.style.transition = 'transform 0.25s cubic-bezier(0.33,1,0.68,1)';
      stageFrame.style.transition = 'transform 0.25s cubic-bezier(0.33,1,0.68,1)';
      card.style.transform = 'scale(0.97) translateY(6px)';
      stageFrame.style.transform = 'scale(0.98) translateY(4px)';

      setTimeout(function(){
        // Phase 2: swap content
        document.querySelector('#project-main-img').src = p.img;
        document.querySelector('#project-title').textContent = p.title;
        var n = document.querySelector('#project-number');
        if(n){ n.textContent = p.id; n.style.backgroundColor = p.color+'1A'; n.style.color = p.color; }
        var d = document.querySelector('#project-desc');
        if(d){ d.textContent = p.desc; d.style.color = p.color; }
        var l = document.querySelector('#project-long');
        if(l) l.textContent = p.long;
        var w = document.querySelector('#watermark');
        if(w){ w.textContent = p.id; w.style.color = p.color+'12'; }
        var s = document.querySelector('#separator');
        if(s) s.style.backgroundColor = p.color+'66';
        var t = document.querySelector('#project-tags');
        if(t){
          t.textContent = '';
          p.tags.forEach(function(tg){
            var tag = document.createElement('span');
            tag.className = 'text-[11px] px-[10px] py-1 rounded-full font-medium';
            tag.style.background = p.color+'26';
            tag.style.color = p.color;
            tag.textContent = tg;
            t.appendChild(tag);
          });
        }
        var sf = document.querySelector('#stage-frame');
        if(sf) sf.style.boxShadow = '4px 4px 0px 0px '+p.color+',0px 12px 32px 0px '+(p.color+'1F')+',inset 0px -6px 0px 0px rgba(0,0,51,0.06)';
        card.style.boxShadow = '4px 4px 0px 0px '+p.color+',0px 12px 32px 0px '+(p.color+'1F');

        for(var i=0; i<totalProjects; i++){
          var dot = document.querySelector('#step-'+i+' span');
          if(dot){ dot.style.fontWeight='800';
            if(i===idx){ dot.style.backgroundColor='#12A59426'; dot.style.color='#0E9888'; dot.style.border='1px dashed #12A594'; dot.style.boxShadow='0px 3px 20px 0px rgba(18,165,148,0.15)'; }
            else { dot.style.backgroundColor='#0090FF1A'; dot.style.color='#0090FF'; dot.style.border='none'; dot.style.boxShadow='none'; }
          }
        }
        var activeStep = document.getElementById('step-'+idx);
        if(activeStep) activeStep.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });

        // Phase 3: rise
        requestAnimationFrame(function(){
          card.style.transform = 'scale(1) translateY(0)';
          stageFrame.style.transform = 'scale(1) translateY(0)';
        });

        setTimeout(function(){
          card.style.transition = '';
          stageFrame.style.transition = '';
          isAnimating = false;
        }, 400);
        currentIndex=idx;
      }, 250);
    }

    for(var i=0; i<totalProjects; i++){
      (function(idx){
        var el = document.getElementById('step-'+idx);
        if(el) el.addEventListener('click', function(){ switchProject(idx); });
      })(i);
    }

    // ── Update mobile indicator ──
    function updateMobileIndicator(idx) {
      var indicator = document.getElementById('mobile-indicator');
      if (indicator) {
        indicator.textContent = (idx + 1) + ' / ' + totalProjects;
      }
    }

    // ── Mobile prev/next buttons ──
    var mobilePrev = document.getElementById('mobile-prev');
    var mobileNext = document.getElementById('mobile-next');
    if (mobilePrev) {
      mobilePrev.addEventListener('click', function() {
        var newIdx = currentIndex - 1;
        if (newIdx < 0) newIdx = totalProjects - 1;
        switchProject(newIdx);
      });
    }
    if (mobileNext) {
      mobileNext.addEventListener('click', function() {
        var newIdx = currentIndex + 1;
        if (newIdx >= totalProjects) newIdx = 0;
        switchProject(newIdx);
      });
    }

    // ── Override switchProject to also update mobile indicator ──
    var originalSwitchProject = switchProject;
    switchProject = function(idx) {
      originalSwitchProject(idx);
      updateMobileIndicator(idx);
    };
  </script>
</CaseStudyLayout>