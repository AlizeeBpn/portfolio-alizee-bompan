---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import { getImage } from 'astro:assets';
import iniSearch1 from '../../assets/ini-search-1.png';
import iniShowcase from '../../assets/project-showcase-global-search.png';
import teamsIaProject from '../../assets/teams-ia-project.png';
import iniApp from '../../assets/ini-app.png';
import buttonsImg from '../../assets/Buttons.png';
import badgeImg from '../../assets/Badge.png';
import twofaImg from '../../assets/2fa.png';
import sectionIni from '../../assets/section-ini.png.png';

// Recompressées/redimensionnées au build via astro:assets — les sources d'origine
// vont jusqu'à 3837×1965px et étaient envoyées telles quelles au mobile.
const [optIniSearch1, optIniShowcase, optTeamsIaProject, optIniApp, optButtons, optBadge, optTwofa, optSectionIni] = await Promise.all(
  [iniSearch1, iniShowcase, teamsIaProject, iniApp, buttonsImg, badgeImg, twofaImg, sectionIni].map((img) =>
    getImage({ src: img, width: 2000, format: 'webp', quality: 85 })
  )
);

const projectsWithImages = [
{ img: optIniSearch1.src, title:'Recherche globale', id:'01', desc:'CRM Initiative', long:"Remplacement d'une page de résultats statiques par un affichage instantané sous la barre de recherche. Pour structurer l'interface, j'ai croisé l'analyse des données d'usage (priorisation des modules) avec un entretien commercial ciblé (choix des informations secondaires indispensables : statut, montant, contact). Résultat : l'utilisateur identifie immédiatement le bon élément dès la frappe, avec un taux de rétention à 7 jours maintenu au-dessus de 90%.", tags:['Recherche instantanée','Architecture de l\'info','Analyse d\'usage'], color:'#0090FF', objectPosition:'left top' },
  { img: optTeamsIaProject.src, title:'Comptes-rendus IA', id:'02', desc:'Réunions Teams • CRM Initiative', long:"Intégration de l'IA pour l'automatisation des comptes-rendus de réunions. Après une phase de shaping et d'entretiens métiers pour cibler l'usage commercial, j'ai pris en charge le design de la fonctionnalité. Mon périmètre a couvert la matérialisation de l'expérience : participation à la rédaction des prompts, création de l'interface de notation des résultats IA, design des notifications et réalisation UI du FRE (First Run Experience) pour l'activation.", tags:['Interface IA','UX Writing','FRE UI'], color:'#12A594' },
  { img: optIniApp.src, title:'Refonte App Mobile', id:'03', desc:'Application Initiative • React Native', long:"Refonte de l'application mobile. Partant d'un diagnostic de l'existant, j'ai entièrement restructuré l'architecture et les flux utilisateurs. J'ai conçu un design rapide en exploitant des composants React Native et des variables de style alignés sur les contraintes techniques. Pour valider concrètement les interactions, j'ai réalisé des prototypes fonctionnels via v0 et Bolt, permettant de tester les comportements de l'interface en conditions réelles.", tags:['Mobile','React Native','Prototype'], color:'#0090FF' },
  { img: optBadge.src, title:'Design System', id:'04', desc:'Restructuration du Design System : mise au propre de la librairie et unification des anciens et nouveaux designs. Création de la documentation pour l\'équipe et maintenance continue des composants au quotidien.', long:"Unification visuelle du CRM pour corriger les incohérences entre deux anciens designs coexistants. Création et migration des composants sur Figma, mise à jour des variables et synchronisation avec le Storybook. Rédaction d'une documentation claire pour rendre l'équipe autonome.", tags:['Figma','Storybook','Composants'], color:'#12A594' },
  { img: optTwofa.src, title:'Parcours d\'activation 2FA', id:'05', desc:'Sécurité • CRM Initiative', long:"Conception du parcours d'activation de la double authentification. Un travail centré sur l'UX Writing et la clarté de l'interface pour réduire la friction sur une étape souvent perçue comme contraignante. Résultat : une adoption réussie par 71% des utilisateurs actifs.", tags:['UX Writing','Friction UX','Sécurité'], color:'#0090FF' },
  { img: optIniShowcase.src, title:'Tableaux de suivi d\'activité', id:'06', desc:'Dashboards B2B • CRM Initiative', long:"Création d'un formulaire permettant aux managers commerciaux de configurer des tableaux de bord sur-mesure (plusieurs indicateurs et périodes). Mise en page pensée pour une lecture rapide des données, avec un fort accent sur la clarté visuelle et l'UX writing pour des utilisateurs non techniques.", tags:['Data','B2B','Interface'], color:'#0090FF' },
  { img: optSectionIni.src, title:'Édition de devis', id:'07', desc:'Ajout de sections • CRM Initiative', long:"Conception d'un système d'ajout de sections personnalisées et de texte libre dans une interface de devis très dense. Travail d'audit et de \"shaping\" pour hiérarchiser l'information, suivi d'une livraison Figma claire pour faciliter l'intégration technique en autonomie.", tags:['UX Audit','Handoff','Structuration'], color:'#12A594' }
];
---

<CaseStudyLayout title="Initiative CRM — Alizée Bompan" bodyClass="w-full bg-[#F8FAFA]">

  <main class="w-full">
    <div class="flex flex-col gap-6 w-full max-w-[900px] mx-auto pt-4 pb-8 px-6 md:px-12">
      <span class="text-brand-light tracking-[.12em] uppercase text-xs font-medium">UX UI Designer — Alternance 2 ans</span>
      <h1 class="font-['Pphatton',Georgia,sans-serif] max-lg:text-[2.5rem] max-md:text-[2rem] max-sm:text-[1.6rem] text-[3.5rem] font-extrabold leading-[1] text-text-heading">Initiative CRM</h1>
      <p class="font-['Plus_Jakarta_Sans',sans-serif] text-text-muted max-lg:text-[1.05rem] max-md:text-[1rem] max-sm:text-[.9rem] text-[1.2rem] leading-[1.5]">
        Design UX/UI d'un SaaS B2B complexe en méthodologie Shape Up. Du cadrage au handoff technique, je construis les parcours de nouvelles fonctionnalités et je modernise la plateforme via un Design System.
      </p>
      <hr class="border-[#00000012] w-full" />
      <div class="flex flex-wrap gap-8 gap-y-4">
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">2025 — En cours</span></div>
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">Figma, Shape Up, Design System</span></div>
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">initiative-crm</span></div>
      </div>
    </div>
  </main>

  <!-- PROJECT STAGE -->
  <div class="project-stage relative w-full max-w-5xl mx-auto mt-8 lg:mt-12 px-4 max-md:mt-4 max-md:flex max-md:flex-col max-md:gap-4">
    <!-- Stage Frame (image) -->
    <div id="stage-frame" style="border-color:#C2E5FF;box-shadow:4px 4px 0px 0px rgba(0,144,255,1),0px 12px 32px 0px rgba(142,200,246,0.12),inset 0px -6px 0px 0px rgba(0,0,51,0.06);" class="bg-blue-50 border rounded-3xl p-4 md:p-6 lg:p-8 relative overflow-hidden transition-all duration-400 ease-[cubic-bezier(0.33,1,0.68,1)] cursor-pointer max-md:!p-2 max-md:cursor-default">
      <div id="project-img-wrapper" class="rounded-2xl overflow-hidden border border-[#C2E5FF]">
        <img id="project-main-img" src={optIniSearch1.src} width={optIniSearch1.attributes.width} height={optIniSearch1.attributes.height} class="w-full h-auto object-cover aspect-[16/10]" style="object-position:left top" alt="Project mockup" />
      </div>
      <div id="watermark" class="absolute top-4 left-8 text-[120px] font-extrabold font-sans leading-none select-none pointer-events-none z-0 max-md:text-[60px] max-md:top-2 max-md:left-4" style="color:#0090FF12">01</div>
    </div>

    <!-- Project Card (desktop: absolute overlay, mobile: static below image) -->
    <div id="project-card" style="box-shadow:4px 4px 0px 0px rgba(0,144,255,1),0px 12px 32px 0px rgba(142,200,246,0.12);" class="absolute -bottom-6 -left-4 md:-bottom-8 md:-left-8 z-10 w-[300px] md:w-[360px] bg-white rounded-2xl shadow-2xl p-4 md:p-6 border border-gray-100 transition-all duration-400 ease-[cubic-bezier(0.33,1,0.68,1)] max-md:!relative max-md:!bottom-auto max-md:!left-auto max-md:!w-full max-md:!z-0 max-md:cursor-default">
      <div class="flex justify-between items-start mb-3">
        <div>
          <h3 id="project-title" class="font-sans text-[24px] font-extrabold text-[#102848] mb-1 max-md:text-[20px]">Recherche globale</h3>
          <p id="project-desc" class="font-sans text-[15px] font-medium text-[#0090FF]">CRM Initiative</p>
        </div>
        <span id="project-number" class="w-12 h-12 rounded-xl flex items-center justify-center font-extrabold text-lg" style="background-color:#0090FF1A;color:#0090FF">01</span>
      </div>
      <div id="separator" class="w-12 h-[3px] rounded-sm mb-4" style="background-color:#0090FF66"></div>
      <p id="project-long" class="text-[#102848A6] text-[15px] leading-[22px] mb-4">
        Remplacement d'une page de résultats statiques par un affichage instantané sous la barre de recherche. Pour structurer l'interface, j'ai croisé l'analyse des données d'usage (priorisation des modules) avec un entretien commercial ciblé (choix des informations secondaires indispensables : statut, montant, contact). Résultat : l'utilisateur identifie immédiatement le bon élément dès la frappe, avec un taux de rétention à 7 jours maintenu au-dessus de 90%.
      </p>
      <div id="project-tags" class="flex flex-wrap gap-2 mb-5">
        <span class="text-[11px] px-[10px] py-1 rounded-full font-medium whitespace-nowrap" style="background:#0090FF26;color:#0090FF">Recherche instantanée</span>
        <span class="text-[11px] px-[10px] py-1 rounded-full font-medium whitespace-nowrap" style="background:#0090FF26;color:#0090FF">Architecture de l'info</span>
        <span class="text-[11px] px-[10px] py-1 rounded-full font-medium whitespace-nowrap" style="background:#0090FF26;color:#0090FF">Analyse d'usage</span>
      </div>
    </div>

  </div>

  <!-- TIMELINE NAVIGATION -->
  <style>
    .timeline-step::after {
      content: '';
      position: absolute;
      top: calc(48px + 9px + 1.1em + 9px + 8px); /* badge + gap + title ~line-height + gap + half-dot */
      left: 50%;
      height: 3px;
      background: #12A594;
      /* Each dot connects to the next — width spans the gap */
      width: calc(100% + 50px);
      pointer-events: none;
      z-index: 0;
    }
    /* The last step doesn't need a connector */
    .timeline-step:last-child::after {
      display: none;
    }
    .timeline-step span,
    .timeline-step .w-12,
    .timeline-step .w-4 {
      z-index: 2;
      position: relative;
    }
  </style>
  <div class="sticky bottom-0 w-full bg-white/80 backdrop-blur-md border-t border-gray-100 py-4 z-40 mt-8 lg:mt-12">
    <div class="w-full px-6 overflow-x-auto">
      <div id="timeline-row" class="relative flex flex-nowrap items-start w-max mx-auto gap-[50px] max-md:gap-6" style="padding-top:6px;padding-bottom:6px">
        {projectsWithImages.map((p, i) => (
          <div id={`step-${i}`} class="timeline-step flex flex-col items-center cursor-pointer relative flex-shrink-0 w-[156px] gap-[9px]">
            <span class="w-12 h-12 rounded-xl flex items-center justify-center font-extrabold text-lg"
                  style={i === 0
                    ? "font-weight:800;background-color:#12A59426;color:#0E9888;border:1px dashed #12A594;box-shadow:0px 3px 20px 0px rgba(18,165,148,0.15)"
                    : "font-weight:800;background-color:#0090FF1A;color:#0090FF;border:none;box-shadow:none"}>
              {p.id}
            </span>
            <span class="text-[11px] font-semibold whitespace-nowrap text-[#102848]">{p.title}</span>
            <span class="w-4 h-4 bg-[#12A594] rounded-full flex-shrink-0" style="box-shadow:0 0 6px 2px rgba(83,185,171,0.5)"></span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Injecter les données côté serveur → client via define:vars -->
  <script define:vars={{ projectsData: JSON.stringify(projectsWithImages) }}>
    var PROJECTS = JSON.parse(projectsData);
    var currentIndex = 0;
    var totalProjects = PROJECTS.length;

    var card = document.querySelector('#project-card');
    var stageFrame = document.querySelector('#stage-frame');
    var isAnimating = false;
    var cardOnTop = true;

    // ── Drag state ──
    var dragTarget = null;
    var dragStartX = 0, dragStartY = 0;
    var elemStartX = 0, elemStartY = 0;
    var dragged = false;

    // Store accumulated drag offsets per element
    var dragOffsets = {};
    dragOffsets['card'] = { x: 0, y: 0 };
    dragOffsets['stage'] = { x: 0, y: 0 };

    function applyDragOffset(el, key) {
      var o = dragOffsets[key];
      el.style.transform = 'translate(' + o.x + 'px, ' + o.y + 'px)';
    }

    function resetDrag(key) {
      dragOffsets[key] = { x: 0, y: 0 };
      if (key === 'card') { card.style.transform = ''; }
      else { stageFrame.style.transform = ''; }
    }

    // ── Make both cards draggable ──
    function makeDraggable(el, key) {
      el.addEventListener('mousedown', function(e) {
        if (isAnimating) return;
        e.preventDefault();
        dragTarget = el;
        dragged = false;
        dragStartX = e.clientX;
        dragStartY = e.clientY;
        elemStartX = dragOffsets[key].x;
        elemStartY = dragOffsets[key].y;
        el.style.transition = 'none';
        el.style.cursor = 'grabbing';
      });

    }

    function onMove(e) {
      if (!dragTarget) return;
      var cx, cy;
      if (e.touches) { cx = e.touches[0].clientX; cy = e.touches[0].clientY; }
      else { cx = e.clientX; cy = e.clientY; }
      var dx = cx - dragStartX;
      var dy = cy - dragStartY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) dragged = true;
      var key = dragTarget === card ? 'card' : 'stage';
      dragOffsets[key].x = elemStartX + dx;
      dragOffsets[key].y = elemStartY + dy;
      dragTarget.style.transform = 'translate(' + dragOffsets[key].x + 'px, ' + dragOffsets[key].y + 'px)';
    }

    function onUp() {
      if (!dragTarget) return;
      var key = dragTarget === card ? 'card' : 'stage';
      dragTarget.style.transition = 'transform 0.4s cubic-bezier(0.33,1,0.68,1)';
      dragTarget.style.cursor = '';
      dragTarget = null;
    }

    makeDraggable(card, 'card');
    makeDraggable(stageFrame, 'stage');
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);

    // ── Swipe on timeline (mobile/tablet) to switch projects ──
    var timelineRow = document.querySelector('#timeline-row');
    if (timelineRow) {
      var touchStartX = 0, touchStartY = 0;
      timelineRow.addEventListener('touchstart', function(e) {
        if (isAnimating || e.touches.length !== 1) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      timelineRow.addEventListener('touchend', function(e) {
        if (isAnimating || !touchStartX) return;
        var deltaX = (e.changedTouches[0] ? e.changedTouches[0].clientX : touchStartX) - touchStartX;
        var deltaY = (e.changedTouches[0] ? e.changedTouches[0].clientY : touchStartY) - touchStartY;
        if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > Math.abs(deltaY)) {
          if (deltaX < 0) {
            switchProject(currentIndex + 1 >= totalProjects ? 0 : currentIndex + 1);
          } else {
            switchProject(currentIndex - 1 < 0 ? totalProjects - 1 : currentIndex - 1);
          }
        }
        touchStartX = 0; touchStartY = 0;
      });
    }

    // ── Z-index swap (only on non-drag clicks) ──
    stageFrame.addEventListener('click', function(e){
      if (dragged || isAnimating) { dragged = false; return; }
      e.stopPropagation();
      cardOnTop = false;
      card.style.zIndex = '5';
      stageFrame.style.zIndex = '20';
    });

    card.addEventListener('click', function(e){
      if (dragged || isAnimating) { dragged = false; return; }
      e.stopPropagation();
      cardOnTop = true;
      card.style.zIndex = '10';
      stageFrame.style.zIndex = '0';
    });

    // ── Project switcher (resets drag positions) ──
    function switchProject(idx) {
      if (idx === currentIndex || isAnimating) return;
      isAnimating = true;
      var p = PROJECTS[idx];

      // Reset drag offsets
      resetDrag('card');
      resetDrag('stage');

      // Phase 1: retreat
      card.style.transition = 'transform 0.25s cubic-bezier(0.33,1,0.68,1)';
      stageFrame.style.transition = 'transform 0.25s cubic-bezier(0.33,1,0.68,1)';
      card.style.transform = 'scale(0.97) translateY(6px)';
      stageFrame.style.transform = 'scale(0.98) translateY(4px)';

      setTimeout(function(){
        // Phase 2: swap content
        document.querySelector('#project-main-img').src = p.img;
        document.querySelector('#project-main-img').style.objectPosition = p.objectPosition || 'center';
        document.querySelector('#project-title').textContent = p.title;
        var n = document.querySelector('#project-number');
        if(n){ n.textContent = p.id; n.style.backgroundColor = p.color+'1A'; n.style.color = p.color; }
        var d = document.querySelector('#project-desc');
        if(d){ d.textContent = p.desc; d.style.color = p.color; }
        var l = document.querySelector('#project-long');
        if(l) l.textContent = p.long;
        var w = document.querySelector('#watermark');
        if(w){ w.textContent = p.id; w.style.color = p.color+'12'; }
        var s = document.querySelector('#separator');
        if(s) s.style.backgroundColor = p.color+'66';
        var t = document.querySelector('#project-tags');
        if(t){
          t.textContent = '';
          p.tags.forEach(function(tg){
            var tag = document.createElement('span');
            tag.className = 'text-[13px] px-[10px] py-1 rounded-full font-medium whitespace-nowrap';
            tag.style.background = p.color+'26';
            tag.style.color = p.color;
            tag.textContent = tg;
            t.appendChild(tag);
          });
        }
        var sf = document.querySelector('#stage-frame');
        if(sf) sf.style.boxShadow = '4px 4px 0px 0px '+p.color+',0px 12px 32px 0px '+(p.color+'1F')+',inset 0px -6px 0px 0px rgba(0,0,51,0.06)';
        card.style.boxShadow = '4px 4px 0px 0px '+p.color+',0px 12px 32px 0px '+(p.color+'1F');

        for(var i=0; i<totalProjects; i++){
          var dot = document.querySelector('#step-'+i+' span');
          if(dot){ dot.style.fontWeight='800';
            if(i===idx){ dot.style.backgroundColor='#12A59426'; dot.style.color='#0E9888'; dot.style.border='1px dashed #12A594'; dot.style.boxShadow='0px 3px 20px 0px rgba(18,165,148,0.15)'; }
            else { dot.style.backgroundColor='#0090FF1A'; dot.style.color='#0090FF'; dot.style.border='none'; dot.style.boxShadow='none'; }
          }
        }
        var activeStep = document.getElementById('step-'+idx);
        if(activeStep) activeStep.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });

        // Phase 3: rise
        requestAnimationFrame(function(){
          card.style.transform = 'scale(1) translateY(0)';
          stageFrame.style.transform = 'scale(1) translateY(0)';
        });

        setTimeout(function(){
          card.style.transition = '';
          stageFrame.style.transition = '';
          isAnimating = false;
        }, 400);
        currentIndex=idx;
      }, 250);
    }

    for(var i=0; i<totalProjects; i++){
      (function(idx){
        var el = document.getElementById('step-'+idx);
        if(el) el.addEventListener('click', function(){ switchProject(idx); });
      })(i);
    }

  </script>
</CaseStudyLayout>