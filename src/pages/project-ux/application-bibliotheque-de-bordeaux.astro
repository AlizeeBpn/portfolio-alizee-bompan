---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import TableOfContents from '../../components/TableOfContents';
---

<CaseStudyLayout
  title="Bibliothèques de Bordeaux — Alizée Bompan"
  bodyClass="w-full bg-[#F4FBFB] font-['Plus_Jakarta_Sans',sans-serif] text-[#222123]"
>

  <!-- ==================== PROJECT HEADER ==================== -->
  <main id="section-hero" class="w-full">
    <div class="flex flex-col gap-10 w-full max-w-[900px] mx-auto pt-8 pb-16 px-6 md:px-12 max-sm:text-center max-sm:items-center">
      <span class="text-[#357E7D] tracking-[.12em] uppercase text-xs font-medium max-sm:text-[.7rem]">Projet de Fin d'Études · Manager de Projets Digitaux UX/UI · 2026</span>
      <h1 class="font-['Lora',serif] [overflow-wrap:anywhere] max-lg:text-[3rem] max-md:text-[2.4rem] max-sm:text-[1.9rem] text-[4rem] font-extrabold leading-[1] text-[#204140]">Bibliothèques de Bordeaux</h1>
      <p class="font-['Plus_Jakarta_Sans',sans-serif] text-[#656366] text-[1.4rem] leading-[1.6] max-sm:text-[1rem]">
        Modernisation de l'écosystème digital d'un réseau de 11 bibliothèques. Refonte d'un site web desktop-first et conception d'une application mobile compagnon, du cadrage utilisateur aux tests d'itération.
      </p>
      <hr class="border-[#00000012] w-full" />
      <div class="flex flex-wrap gap-12 gap-y-6">
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">2026</span></div>
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">Figma, React, PWA, Design System</span></div>
        <div class="flex flex-col gap-1"><span class="text-[#bbb] tracking-[.1em] uppercase text-[.7rem]">bibliotheque-bordeaux</span></div>
      </div>
    </div>
  </main>

  <!-- ==================== HERO / COVER ==================== -->
  <section class="relative w-full min-h-screen flex items-center overflow-hidden" style="background:linear-gradient(45deg,#F4FBFB 0%,#FFFFFF 81%)">
    <div class="w-full max-w-[1400px] mx-auto px-6 md:px-16 py-20 grid md:grid-cols-[1fr_auto] gap-12 items-center">
      <div class="min-w-0 flex flex-col gap-6">
        <span class="text-[#357E7D] tracking-[.12em] uppercase text-sm font-semibold max-sm:text-[.7rem]">Projet de Fin d'Études · Manager de Projets Digitaux UX/UI · 2026</span>
        <h2 class="font-['Lora',serif] text-[1.5rem] md:text-[2.5rem] font-bold leading-[1.2] text-[#204140]">Modernisation de l'Écosystème</h2>
        <h1 class="font-['Lora',serif] [overflow-wrap:anywhere] text-[2.5rem] md:text-[5rem] font-bold leading-[1] text-[#204140] max-sm:leading-[1.1]">Bibliothèques<br/>de Bordeaux</h1>
        <div class="flex flex-col gap-3 mt-4 max-sm:gap-2">
          {[
            { num: '01.', label: 'Contexte' },
            { num: '02.', label: 'Design System' },
            { num: '03.', label: 'Spécifications fonctionnelles' },
            { num: '04.', label: 'Tests Utilisateur & Itération' }
          ].map((item) => (
            <div class="inline-flex items-center gap-3 self-start bg-[#F8E2EA] border border-[#F4D2DE] rounded-2xl px-6 py-3">
              <span class="font-['Lora',serif] font-bold text-[#7D193E] text-lg">{item.num}</span>
              <span class="font-['Lora',serif] font-bold text-[#4D0F26] text-xl">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hidden md:flex flex-col items-center gap-4">
        <div class="w-[280px] h-[580px] bg-[#204140] rounded-[2.5rem] p-2 shadow-2xl">
          <div class="w-full h-full bg-white rounded-[2rem] overflow-hidden">
            <img src="/images/bibliotheque-bordeaux/cover-iphone.png" alt="Mockup application Bibliothèques de Bordeaux" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SECTION DIVIDER: CONTEXTE ==================== -->
  <div id="section-contexte" class="w-full bg-[#F4FBFB] py-16">
    <div class="max-w-[1400px] mx-auto px-6 md:px-16 text-center">
      <h2 class="font-['Lora',serif] text-[3rem] md:text-[4rem] font-bold text-[#204140] tracking-[-0.02em] max-sm:text-[2rem]">CONTEXTE</h2>
    </div>
  </div>

  <!-- ==================== LE RÉSEAU : UN PILIER CULTUREL ==================== -->
  <section class="w-full py-16 md:py-24 subsection" id="sub-reseau">
    <div class="subsection-summary max-w-[1400px] mx-auto px-6 md:px-16 mb-8 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473] max-sm:text-[1.5rem]">Le Réseau : Un Pilier Culturel</h3>
      
    </div>
    <div class="subsection-content max-w-[1400px] mx-auto px-6 md:px-16">
      <p class="text-[1.25rem] md:text-[1.5rem] leading-[1.5] text-[#222123] mb-12 max-w-[900px] max-sm:text-[1rem]">
        Le réseau des bibliothèques de Bordeaux est le premier acteur culturel de proximité, desservant <strong>261 000 habitants.</strong>
      </p>

      <!-- Stats cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        {[
          { icon: '🏛', num: '11', label: 'Bibliothèques\n(dont Mériadeck)' },
          { icon: '📚', num: '1,3 M', label: 'documents\ndisponibles' },
          { icon: '👪', num: '20 %', label: "taux d'inscription\n(sup. moy. nationale)" },
          { icon: '📖', num: '1,3 M', label: "d'emprunts\n(inférieurs à d'autres réseaux comparables)" }
        ].map((stat) => (
          <div class="bg-[#F9F9FA] border border-[#E9E8EA] rounded-2xl p-6 flex flex-col items-center text-center gap-2">
            <span class="text-3xl">{stat.icon}</span>
            {stat.num && <span class="font-['Lora',serif] text-[2rem] font-bold text-[#204140]">{stat.num}</span>}
            <span class="text-sm text-[#828183] whitespace-pre-line leading-[1.3]">{stat.label}</span>
          </div>
        ))}
      </div>

      <!-- Mission & Enjeu -->
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-[#E1F7F6] rounded-2xl p-8">
          <span class="text-[#357E7D] font-semibold tracking-[.08em] uppercase text-sm">MISSION</span>
          <p class="text-[1.1rem] leading-[1.5] text-[#656366] mt-4">Rendre la culture et le savoir accessibles à tous, gratuitement, quel que soit le milieu.</p>
        </div>
        <div class="bg-[#E1F7F6] rounded-2xl p-8">
          <span class="text-[#357E7D] font-semibold tracking-[.08em] uppercase text-sm">ENJEU NUMÉRIQUE</span>
          <p class="text-[1.1rem] leading-[1.5] text-[#656366] mt-4">Moderniser l'écosystème digital pour rester un acteur de proximité pertinent et inclusif.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== DIAGNOSTIC UX ==================== -->
  <section class="w-full py-16 md:py-24 bg-[#FAFEFD] subsection" id="sub-diagnostic">
    <div class="subsection-summary max-w-[1400px] mx-auto px-6 md:px-16 mb-6 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473] max-sm:text-[1.5rem]">Diagnostic UX : Complexité & Défis</h3>
      
    </div>
    <div class="subsection-content max-w-[1400px] mx-auto px-6 md:px-16">

      <div class="grid md:grid-cols-[1fr_500px] gap-x-8 max-md:grid-cols-1 max-md:gap-y-6">
        <!-- Left column: cards + link pushed to bottom -->
        <div class="flex flex-col">
          <div class="mt-auto flex flex-col gap-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-[#F8E2EA] border border-[#F4D2DE] rounded-2xl p-8">
                <span class="text-4xl">⚠️</span>
                <span class="block font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#204140] text-xl mt-4 mb-2">60+ sous-pages</span>
                <span class="block text-[#7D193E] font-semibold tracking-[.08em] uppercase text-sm mb-4">SURCHARGE COGNITIVE</span>
                <p class="text-[1.05rem] leading-[1.5] text-[#656366]">Architecture dense : 8 sections de menu avec 6 à 11 sous-pages chacune. Des intitulés peu évocateurs et une navigation qui ouvre fréquemment de nouvelles pages rendent le retour en arrière difficile, notamment sur mobile.</p>
              </div>
              <div class="bg-[#F8E2EA] border border-[#F4D2DE] rounded-2xl p-8">
                <span class="text-4xl">📱</span>
                <span class="block font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#204140] text-xl mt-4 mb-2">Approche Desktop-first</span>
                <span class="block text-[#7D193E] font-semibold tracking-[.08em] uppercase text-sm mb-4">DÉFICIT MOBILE</span>
                <p class="text-[1.05rem] leading-[1.5] text-[#656366]">Une approche historiquement "Desktop-first". Des icônes sans libellés, des zones tactiles exiguës et une conformité RGAA partielle (74,7%) freinent l'inclusion numérique.</p>
              </div>
            </div>
            <!-- Link aligned with bottom of image -->
            <a href="https://bibliotheque.bordeaux.fr/" target="_blank" rel="noopener" class="inline-block bg-[#E1F7F6] rounded-full px-6 py-2 self-start">
              <span class="font-['Lora',serif] font-bold text-[#204140] underline text-base">Lien du site Bibliothèques de Bordeaux</span>
            </a>
          </div>
        </div>
        <!-- Mockup image on the right -->
        <img src="/images/image-pc-desktop.png" alt="Mockup desktop et mobile du site Bibliothèques de Bordeaux" class="w-full h-auto rounded-xl" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ==================== CIBLES & PROFILS ==================== -->
  <section class="w-full py-16 md:py-24 subsection" id="sub-cibles">
    <div class="subsection-summary max-w-[1400px] mx-auto px-6 md:px-16 mb-4 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473] max-sm:text-[1.5rem]">Cibles & Profils Utilisateurs</h3>
      
    </div>
    <div class="subsection-content max-w-[1400px] mx-auto px-6 md:px-16">
      <p class="text-[1.25rem] leading-[1.4] text-[#222123] mb-8 max-w-[900px] max-sm:text-[1rem]">Trois archétypes structurent les priorités UX, ils peuvent coexister chez un même usager</p>

      <!-- Demographics -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        {[
          { num: '65 %', label: 'Adultes (18-64 ans)' },
          { num: '25 %', label: 'Scolaires' },
          { num: '11 %', label: 'Étudiants' },
          { num: '11 %', label: 'Retraités' }
        ].map((d) => (
          <div class="bg-[#E1F7F6] rounded-2xl p-6 text-center">
            {d.num && <span class="block font-['Lora',serif] text-[2rem] font-bold text-[#204140]">{d.num}</span>}
            <span class="block text-sm text-[#357E7D] mt-1">{d.label}</span>
          </div>
        ))}
      </div>

      <!-- Personas -->
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: '🎓', title: 'Étudiant/Scolaire/Professionnel', focus: 'Focus : Efficacité', items: ['Recherche documentaire précise', 'Vérification de disponibilité immédiate', 'Réservation de salles d\'étude', 'Localisation exacte (étage, rayon, cote)', 'Accès aux ressources numériques en ligne'] },
          { icon: '🛋️', title: 'Le Flâneur', focus: 'Focus : Découverte', items: ['Recommandations selon ses goûts', 'Navigation par genres & ambiances', 'Événements, ateliers, clubs, nouveautés', 'Suggestions éditoriales des bibliothécaires', 'Découverte spontanée du catalogue'] },
          { icon: '♿', title: 'Public Fragile', focus: 'Focus : Inclusion', items: ['Clarté cognitive maximale', 'Conformité RGAA (accessibilité complète)', 'Accès gratuit à Internet sur place', 'Accompagnement aux démarches admin.', 'Aide à la recherche d\'emploi'] }
        ].map((p) => (
          <div class="min-w-0 bg-[#F9F9FA] border border-[#E9E8EA] rounded-2xl p-8">
            <span class="text-4xl">{p.icon}</span>
            <span class="block [overflow-wrap:anywhere] text-[#357E7D] font-semibold tracking-[.08em] uppercase text-sm mt-4 mb-2">{p.title}</span>
            <span class="block font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#204140] text-lg mb-4">{p.focus}</span>
            <ul class="space-y-2">
              {p.items.map((item) => (
                <li class="text-sm text-[#656366] leading-[1.4] flex gap-2"><span class="text-[#357E7D]">•</span>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FRUSTRATIONS UTILISATEURS ==================== -->
  <section class="w-full py-16 md:py-24 bg-[#FAFEFD] subsection" id="sub-frustrations">
    <div class="subsection-summary max-w-[1400px] mx-auto px-6 md:px-16 mb-12 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473] max-sm:text-[1.5rem]">Les frustrations Utilisateurs</h3>
      
    </div>
    <div class="subsection-content max-w-[1400px] mx-auto px-6 md:px-16">

      <div class="grid md:grid-cols-3 gap-6 mb-8">
        {[
          { title: "L'aversion au risque (L'investissement temps)", text: "Lire exige un engagement temporel fort. L'usager a un besoin crucial de certitude et de réassurance avant d'emprunter, ce qui rend la recherche du \"bon\" livre particulièrement exigeante." },
          { title: 'Le refuge de la popularité', text: "Face à la difficulté de trouver une correspondance parfaite avec leurs goûts, les lecteurs se rabattent sur les best-sellers pour minimiser le risque de déception, invisibilisant ainsi le reste du catalogue." },
          { title: 'La friction du parcours in situ', text: "Même lorsque le choix est fait, la recherche physique de l'ouvrage en bibliothèque reste difficile (déchiffrage de la signalétique, contraintes ergonomiques nécessitant de se pencher pour scruter les rayonnages)." }
        ].map((f) => (
          <div class="bg-[#FEF6F9] border border-[#F8E2EA] rounded-2xl p-8">
            <span class="block font-['Lora',serif] font-bold text-[#7D193E] text-lg mb-4">{f.title}</span>
            <p class="text-[1rem] leading-[1.5] text-[#222123]">{f.text}</p>
          </div>
        ))}
      </div>

      <!-- Green pills -->
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-[#E1F7F6] rounded-2xl p-6 flex items-center justify-center">
          <p class="font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#25706F] text-base text-center">Les recommandations et les avis sont plébiscités</p>
        </div>
        <div class="bg-[#E1F7F6] rounded-2xl p-6 flex items-center justify-center">
          <p class="font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#25706F] text-base text-center">80 % du temps passé sur le web se fait sur smartphone et 94 % de ce temps est consacré aux applications mobiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== LA PROBLÉMATIQUE ==================== -->
  <section class="w-full py-20 md:py-32 text-center subsection" id="sub-problematique">
    <div class="subsection-summary max-w-[1000px] mx-auto px-6 mb-12 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473]">La Problématique</h3>
      
    </div>
    <div class="subsection-content max-w-[1000px] mx-auto px-6">
      <p class="font-['Lora',serif] text-[1.5rem] md:text-[2rem] leading-[1.3] text-[#357E7D] font-semibold tracking-[-0.022em]">
        Comment simplifier l'exploration d'un catalogue numérique massif en proposant une expérience mobile fluide, pour stimuler la découverte de titres et relancer la dynamique d'emprunt ?
      </p>
    </div>
  </section>

  <!-- ==================== STRATÉGIE DIGITALE HYBRIDE ==================== -->
  <section class="w-full py-16 md:py-24 bg-[#FAFEFD] subsection" id="sub-strategie">
    <div class="subsection-summary max-w-[1400px] mx-auto px-6 md:px-16 mb-12 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473]">Une Stratégie Digitale Hybride</h3>
      
    </div>
    <div class="subsection-content max-w-[1400px] mx-auto px-6 md:px-16">

      <div class="grid md:grid-cols-3 gap-6 items-start max-sm:grid-cols-1">
        <!-- Stratégie hybride card -->
        <div class="bg-[#E1F7F6] rounded-2xl p-8 self-center">
          <span class="text-4xl">💡</span>
          <span class="block font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#204140] text-lg mt-4 mb-2">Stratégie hybride</span>
          <span class="block text-[#357E7D] font-semibold tracking-[.08em] uppercase text-sm mb-4">RÉPONSE PROPOSÉE</span>
          <p class="text-[1rem] leading-[1.5] text-[#656366]">Deux écosystèmes complémentaires pour répondre à deux modes d'usage distincts</p>
        </div>
        <!-- App Compagnon -->
        <div class="bg-[#F9F9FA] border border-[#E9E8EA] rounded-2xl p-8">
          <span class="text-4xl">📱</span>
          <span class="block font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#204140] text-lg mt-4 mb-2">Usage Fonctionnel</span>
          <span class="block text-[#357E7D] font-semibold tracking-[.08em] uppercase text-sm mb-4">APP COMPAGNON</span>
          <ul class="space-y-2">
            {['Scan ISBN en rayon (accès fiche instantané)', 'Carte numérique adhérent (code-barres)', 'Réservation de services & salles', 'Emprunts en cours & prochains retours', 'Suggestions personnalisées', 'Navigation dans les espaces physiques'].map((item) => (
              <li class="text-sm text-[#656366] leading-[1.4] flex gap-2"><span class="text-[#357E7D]">•</span>{item}</li>
            ))}
          </ul>
        </div>
        <!-- Site Web Refondu -->
        <div class="bg-[#F9F9FA] border border-[#E9E8EA] rounded-2xl p-8">
          <span class="text-4xl">🖥️</span>
          <span class="block font-['Plus_Jakarta_Sans',sans-serif] font-bold text-[#204140] text-lg mt-4 mb-2">Usage Informationnel</span>
          <span class="block text-[#357E7D] font-semibold tracking-[.08em] uppercase text-sm mb-4">SITE WEB REFONDU</span>
          <ul class="space-y-2">
            {['Point d\'entrée pour nouveaux visiteurs', 'Catalogue patrimonial & ressources Séléné', 'Agenda culturel & actualités du réseau', 'Inscription et découverte du réseau', 'Architecture simplifiée mobile-first', 'Conformité RGAA renforcée'].map((item) => (
              <li class="text-sm text-[#656366] leading-[1.4] flex gap-2"><span class="text-[#357E7D]">•</span>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SECTION DIVIDER: SPÉCIFICATIONS ==================== -->
  <div id="section-specs" class="w-full py-16 md:py-20 text-center" style="background:linear-gradient(45deg,#F4FBFB 0%,#FCFCFD 100%)">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="font-['Lora',serif] text-[3rem] md:text-[4rem] font-bold text-[#204140] tracking-[-0.02em] mb-4 max-sm:text-[2rem]">SPÉCIFICATIONS FONCTIONNELLES</h2>
      <p class="text-[1.5rem] md:text-[1.75rem] text-[#357E7D] leading-[1.4] max-sm:text-[1.1rem]">Construction de l'application mobile</p>
    </div>
  </div>

  <!-- ==================== FONCTIONNALITÉS DE L'APPLICATION ==================== -->
  <section class="w-full py-16 md:py-24 subsection" id="sub-fonctionnalites" style="background:linear-gradient(45deg,#F4FBFB 0%,#FCFCFD 100%)">
    <div class="subsection-summary max-w-[1400px] mx-auto px-6 md:px-16 mb-12 flex items-center justify-between gap-4">
      <h3 class="font-['Lora',serif] text-[2rem] md:text-[2.5rem] font-bold text-[#297473]">Fonctionnalités de l'Application</h3>
      
    </div>
    <div class="subsection-content max-w-[1400px] mx-auto px-6 md:px-16">

      <div class="space-y-[72px]">
        {[
          {
            num: '01', icon: '🏠', title: "Page d'accueil", items: ['Bibliothèque favorite en premier plan', 'Reprendre la lecture (livre numérique en cours)', 'Prochains retours avec dates limites', 'Services à venir & réservations actives'],
            imgs: ['/images/bibliotheque-bordeaux/page_acceuil_1.png', '/images/bibliotheque-bordeaux/page_acceuil_2.png']
          },
          {
            num: '02', icon: '🔍', title: 'Recherche & Catalogue', items: ['Barre de recherche globale', 'Filtres rapides (chips) + filtres avancés', 'Catalogue de suggestions personnalisées par historique', 'Catégories thématiques & par type'],
            imgs: ['/images/bibliotheque-bordeaux/recherche_1.png', '/images/bibliotheque-bordeaux/recherhce_2.png']
          },
          {
            num: '03', icon: '📅', title: 'Réservation de services', items: ['Salles d\'étude & studios musique', 'Instruments de musique & prêt d\'objets', 'Ateliers numériques & soutien scolaire', 'Choix de créneau + confirmation'],
            imgs: ['/images/bibliotheque-bordeaux/service.png']
          },
          {
            num: '04', icon: '👤', title: 'Mon espace', items: ['Emprunts numériques & physiques en cours', 'Listes (favoris, à lire, personnalisées)', 'Historique complet & commentaires', 'Paramètres accessibilité & bibliothèque fav.', 'Ma Carte adhérent (code-barres plein écran)'],
            imgs: ['/images/bibliotheque-bordeaux/espace_1.png', '/images/bibliotheque-bordeaux/espace_2.png']
          },
          {
            num: '05', icon: '📰', title: 'Actualités & Agenda', items: ['Actualités du réseau', 'Agenda culturel filtrable', 'Événements à ajouter en favoris', 'Ateliers, rencontres d\'auteurs, projections'],
            imgs: ['/images/bibliotheque/fonct_agenda.png']
          },
          {
            num: '06', icon: '📷', title: 'Recherche scan ISBN', items: ['Scanner ISBN → fiche ressource instantanée', 'FAB ISBN'],
            imgs: ['/images/bibliotheque-bordeaux/isbn_scan.png']
          }
        ].map((feat) => (
<div class="flex flex-row gap-10 items-start flex-wrap">
