  <style is:global>
    .reveal-scroll {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.45s ease-out, transform 0.45s ease-out;
    }
    .reveal-scroll.revealed {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
    );

    document.querySelectorAll('section, div, h1, h2, h3, h4, h5, p, img, ul, video').forEach((el) => {
      if (!el.classList.contains('reveal-scroll')) {
        el.classList.add('reveal-scroll');
      }
      observer.observe(el);
    });

    // Reveal elements already visible on load with stagger
    window.addEventListener('load', () => {
      const visible = Array.from(document.querySelectorAll('.reveal-scroll')).filter((el) => {
        return el.getBoundingClientRect().top < window.innerHeight;
      });
      visible.forEach((el, i) => {
        setTimeout(() => {
          el.classList.add('revealed');
        }, i * 60);
      });
    });
  </script>

  


